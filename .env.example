# Base de datos.
# La variable que MANDA en la app es DATABASE_URL (URL completa de SQLAlchemy):
#   DATABASE_URL=postgresql+asyncpg://pulso:<password>@db/pulso
# Si no la defines, la app usa el default postgresql+asyncpg://pulso:pulso@db/pulso.
# DB_PASSWORD existe solo para que docker-compose arme esa URL; la app no lee DB_PASSWORD
# directamente. Si defines ambas, DATABASE_URL gana.
DATABASE_URL=postgresql+asyncpg://pulso:changeme@db/pulso
DB_PASSWORD=changeme

# App — OBLIGATORIO en producción. Generar con:
#   python -c "import secrets; print(secrets.token_hex(32))"
# El arranque ABORTA si DEBUG=false y SECRET_KEY sigue en "dev-secret-change-in-production".
SECRET_KEY=changeme

DEBUG=false

# IA — requeridos en F2, opcionales en F1
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Email — requerido en F3
RESEND_API_KEY=

# Worker
JOB_POLL_INTERVAL_SECONDS=10
JOB_LEASE_SECONDS=300
