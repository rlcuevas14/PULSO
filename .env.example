# Base de datos (la app la arma como postgresql+asyncpg://pulso:<DB_PASSWORD>@db/pulso)
DB_PASSWORD=changeme

# App — generar con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme

DEBUG=false

# IA — requeridos en F2, opcionales en F1
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Email — requerido en F3
RESEND_API_KEY=

# Worker
JOB_POLL_INTERVAL_SECONDS=10
JOB_LEASE_SECONDS=300
