# Required
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Startup ABORTS if SECRET_KEY is left at the default in production (DEBUG=false).
SECRET_KEY=change-me

# Required — must match the password in docker-compose.yml
DB_PASSWORD=change-me

# Optional — set when running behind a reverse proxy
# BASE_URL=https://pulso.example.com

# Optional — AI enrichment (impact/effort scoring + semantic search)
# Both degrade gracefully if absent — no errors, enrichment is simply skipped.
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Optional — GitHub container registry owner (used in docker-compose image tag)
# GITHUB_OWNER=your-github-username

# Optional — webhook integration secrets (configured per-project in the UI in a future release)
# GITHUB_WEBHOOK_SECRET=
# SENTRY_CLIENT_SECRET=
# SENTRY_API_TOKEN=
# SENTRY_ORG=

# Advanced
# JOB_POLL_INTERVAL_SECONDS=10
# JOB_LEASE_SECONDS=300
# DEBUG=false
